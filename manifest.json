{
  "manifest_version": 3,
  "host_permissions": ["<all_urls>"],
  "icons": {
  "32": "icon_32.png",
  "48": "icon_48.png",
  "128": "icon_128.png"
},

  "name": "URLY - Encurtador de url",
  "version": "1.0",
  "description": "Extensão para encurtar urls de forma rápida no navegador",
  "action": {
    "default_popup": "popup.html"
  }
}